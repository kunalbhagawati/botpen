name: botpen-{{ slug }}

services:
  agent:
    build:
      context: .
      dockerfile: Dockerfile
    image: botpen-agent-{{ slug }}
    container_name: botpen-{{ slug }}
    env_file: .env
    stdin_open: true
    tty: true
    volumes:
      - {{ shared_volume }}:/shared
    networks:
      # Shared bridge network with the Hub - the agent reaches it by name (hub:8787 / hub:8788).
      - botpen

networks:
  botpen:
    external: true
    name: botpen

volumes:
  {{ shared_volume }}:
    external: true
