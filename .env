# Config for ./messages (the SQLite-backed mailbox).
#
# NOTE: SQLite is a local file with no built-in users or passwords. The "user"
# below is an informational owner tag only - it is NOT an auth credential.

# Path to the SQLite database (relative paths resolve against the bots/ dir).
MESSAGES_DB=messages.db

# Informational identity tags (no auth enforced).
MESSAGES_USER=agents
MESSAGES_APP=bots-mailbox
