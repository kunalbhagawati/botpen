# Base config for the bots mailbox. Read by config.py (pydantic-settings).
#
# ! Works for local dev out of the box. !
#
# Override cascade (only redefine what changes - everything else inherits from here):
#   .env.local   -> personal overrides / secrets (gitignored). Loaded automatically.
#   <env vars>   -> anything set in the real process environment wins over both files.
#
# How it works - same key downstream wins, the rest is inherited from .env:
#
#   .env                       .env.local
#     ├── MESSAGES_DB=a    ->     └── MESSAGES_DB=b
#     └── MESSAGES_USER=x
#   Final -> MESSAGES_DB=b (overridden), MESSAGES_USER=x (inherited)
#
# Precedence (low -> high):   .env   <   .env.local   <   process env vars
#
# NOTE: SQLite is a local file with no built-in users or passwords. MESSAGES_USER /
# MESSAGES_APP are informational owner tags only - NOT auth credentials.


# Path to the SQLite database (relative paths resolve against the repo root).
MESSAGES_DB=messages.db

# Informational identity tags (no auth enforced).
MESSAGES_USER=agents
MESSAGES_APP=bots-mailbox
