# Base config for the bots mailbox. Read by config.py (pydantic-settings).
#
# ! Works for local dev out of the box. !
#
# Override cascade (only redefine what changes - everything else inherits from here):
#   .env.local   -> personal overrides / secrets (gitignored). Loaded automatically.
#   <env vars>   -> anything set in the real process environment wins over both files.
#
# How it works - same key downstream wins, the rest is inherited from .env:
#
#   .env                       .env.local
#     ├── MESSAGES_DB=a    ->     └── MESSAGES_DB=b
#     └── MESSAGES_USER=x
#   Final -> MESSAGES_DB=b (overridden), MESSAGES_USER=x (inherited)
#
# Precedence (low -> high):   .env   <   .env.local   <   process env vars
#
# NOTE: SQLite is a local file with no built-in users or passwords. MESSAGES_USER /
# MESSAGES_APP are informational owner tags only - NOT auth credentials.


# Path to the SQLite database (relative paths resolve against the repo root).
MESSAGES_DB=.db/messages.db

# Informational identity tags (no auth enforced).
MESSAGES_USER=agents
MESSAGES_APP=bots-mailbox

# Claude Code credential injected into scaffolded containers. The real 1-year token (from
# `claude setup-token`) is a SECRET - keep it in .env.local, never here. See README.md.
CLAUDE_CODE_OAUTH_TOKEN="<check README.md>"

# Mailbox daemon (`serve`): the single DB writer that containers reach at host.docker.internal.
# 0.0.0.0 so scaffolded containers can reach the daemon via host.docker.internal.
DAEMON_HOST=0.0.0.0
DAEMON_PORT=8787
DAEMON_WS_PORT=8788

# Redact tokens from request_log. Off by default (local, single-operator system).
REQUEST_LOG_REDACT_TOKEN=false

# Scaffolding defaults. Base image is plain Alpine; stacks are apk-installed on top at build.
SCAFFOLD_BASE_IMAGE=alpine:3.21
ACL_HELPER_IMAGE=alpine:3.21
SHARED_VOLUME_NAME=botpen_shared
SHARED_VOLUME_SIZE_GB=20
SCAFFOLD_DEFAULT_MAX_DISK_MB=512
SCAFFOLD_UID_BASE=20000
SCAFFOLD_GID_BASE=20000

SCAFFOLD_TEARDOWN_AFTER_MINS=1440 # 24 hours. After an agent's container stops, the Hub will wait this long before reaping its
